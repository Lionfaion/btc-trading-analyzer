# Supabase Configuration
# Copy this file to .env.local and fill in your credentials from https://supabase.com/dashboard

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: For testing with curl
# Get a valid JWT token from Supabase Auth:
# 1. Sign up at your app
# 2. Open DevTools → Network → look for Authorization header
# 3. Copy token and use: curl -H "Authorization: Bearer TOKEN" ...
